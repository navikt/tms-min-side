---
import { getAudience, getOboToken } from "../../utils/server/token";
import { fetchData } from "../../utils/server/fetch";

interface Props {
  url: string;
  appname: string;
  namespace: string;
  fallback: string;
}

const { url, appname, namespace, fallback } = Astro.props;
const audience = getAudience(appname, namespace);
const oboToken = await getOboToken(Astro.locals.token, audience);
let html;

console.info("Url:", `${url}/nb`);

try {
  html = await fetchData(oboToken, `${url}/nb`);
} catch (error) {
  console.error(`Failed to fetch ${appname}. Error: `, error);
}

/*
const html = await fetch(`${url}/nb`, {
  method: "GET",
  headers: {
    "Content-Type": "application/json",
    Accept: "application/json",
    Authorization: `Bearer ${oboToken}`,
  },
}).catch((e) => console.error("Failed to fetch ssr-microfrontend. Error:" + e.message));
*/
---

<Fragment set:html={html} />
