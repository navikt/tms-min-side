---
import { PUBLIC_LEGACY_SELECTOR_URL, PUBLIC_TELEMETRY_URL } from "astro:env/server";
import Aktuelt from "@src/features/aktuelt/Aktuelt.astro";
import AlertIsland from "@src/features/alert-island/AlertIsland.astro";
import DinOversikt from "@src/features/din-oversikt/DinOversikt.astro";
import Dokumenter from "@src/features/dokumenter/Dokumenter.astro";
import DokumenterFallback from "@src/features/dokumenter/fallback/DokumenterFallback.astro";
import InnboksFallback from "@src/features/innboks/fallback/InnboksFallback.astro";
import Innboks from "@src/features/innboks/Innboks.astro";
import InnloggedeTjenester from "@src/features/innloggede-tjenester/InnloggedeTjenester.astro";
import Personalia from "@src/features/personalia/Personalia.astro";
import SubstantialInfo from "@src/features/substantial-info/SubstantialInfo.astro";
import UtbetalingFallback from "@src/features/utbetaling/fallback/UtbetalingFallback.astro";
import Utbetaling from "@src/features/utbetaling/Utbetaling.astro";
import Layout from "@src/layouts/base/Layout.astro";
import Content from "@src/layouts/content/Content.astro";
import Container from "@src/shared/container/Container.astro";
import Feilmelding from "@src/shared/feilmelding/Feilmelding";
import Legacy from "@src/shared/legacy/Legacy";
import Observability from "@src/shared/obersvability/Observability";
import type { Language } from "@src/shared/utils/server/language";

const language = Astro.currentLocale as Language;
---

<Layout title="Min side" breadcrumbs={[]}>
  <Content cls="min-side">
    <SubstantialInfo />
    <Feilmelding language={language} client:only="react" />
    <Personalia />
    <AlertIsland />
    <DinOversikt server:defer />
    <Container>
      <Utbetaling server:defer>
        <UtbetalingFallback slot="fallback" />
      </Utbetaling>
      <Innboks server:defer>
        <InnboksFallback slot="fallback" />
      </Innboks>
      <Dokumenter server:defer>
        <DokumenterFallback slot="fallback" />
      </Dokumenter>
      <Aktuelt server:defer />
    </Container>
    <InnloggedeTjenester />
  </Content>
  <Legacy language={language} url={PUBLIC_LEGACY_SELECTOR_URL} client:only="react" />
  <Observability url={PUBLIC_TELEMETRY_URL} client:only="react" />
</Layout>
