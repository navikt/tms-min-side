---
import { PUBLIC_LEGACY_SELECTOR_URL, PUBLIC_TELEMETRY_URL } from "astro:env/server";
import AlertIsland from "@features/alert-island/AlertIsland.astro";
import Innboks from "@features/innboks/Innboks.astro";
import InnloggedeTjenester from "@features/innloggede-tjenester/InnloggedeTjenester.astro";
import Personalia from "@features/personalia/Personalia.astro";
import SubstantialInfo from "@features/substantial-info/SubstantialInfo.astro";
import Utbetaling from "@features/utbetaling/Utbetaling.astro";
import Container from "@shared/container/Container.astro";
import Feilmelding from "@shared/feilmelding/Feilmelding";
import Legacy from "@shared/legacy/Legacy";
import Observability from "@shared/obersvability/Observability";
import Aktuelt from "../../features/aktuelt/Aktuelt.astro";
import DinOversikt from "../../features/din-oversikt/DinOversikt.astro";
import Dokumenter from "../../features/dokumenter/Dokumenter.astro";
import DokumenterFallback from "../../features/dokumenter/fallback/DokumenterFallback.astro";
import InnboksFallback from "../../features/innboks/fallback/InnboksFallback.astro";
import UtbetalingFallback from "../../features/utbetaling/fallback/UtbetalingFallback.astro";
import Layout from "../../layouts/base/Layout.astro";
import Content from "../../layouts/content/Content.astro";
import type { Language } from "../../utils/server/language";

const language = Astro.currentLocale as Language;
---

<Layout title="Min side" breadcrumbs={[]}>
  <Content cls="min-side">
    <SubstantialInfo />
    <Feilmelding language={language} client:only="react" />
    <Personalia />
    <AlertIsland />
    <DinOversikt server:defer />
    <Container>
      <Utbetaling server:defer>
        <UtbetalingFallback slot="fallback" />
      </Utbetaling>
      <Innboks server:defer>
        <InnboksFallback slot="fallback" />
      </Innboks>
      <Dokumenter server:defer>
        <DokumenterFallback slot="fallback" />
      </Dokumenter>
      <Aktuelt server:defer />
    </Container>
    <InnloggedeTjenester />
  </Content>
  <Legacy language={language} url={PUBLIC_LEGACY_SELECTOR_URL} client:only="react" />
  <Observability url={PUBLIC_TELEMETRY_URL} client:only="react" />
</Layout>
