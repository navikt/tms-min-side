---
import { BodyLong, Heading } from "@navikt/ds-react";
import styles from "@src/features/dokumenter/Dokumenter.module.css";
import { text } from "@src/features/dokumenter/dokumenterText";
import type { Language } from "@src/shared/utils/server/language";

interface Props {
  language: Language;
}

const { language } = Astro.props;
---

<div class={styles.container}>
  <div class={styles.ingenHeadingContainer}>
    <Heading level="2" size="xsmall">
      {text.heading[language]}
    </Heading>
  </div>
  <div class={styles.ingenIngressContainer}>
    <BodyLong className={styles.ingenText}>{text.minidIngress[language]}</BodyLong>
  </div>
</div>
