---
import { beskjedSingular, buildText, hasVarsler, oppgaveSingular } from './varslerUtils';
import { text } from './varslerText';
import { getAudience, getOboToken } from '../../../utils/server/token';
import { fetchData } from '../../../utils/server/fetch';
import { VARSLER_URL, VARSEL_API_URL } from 'astro:env/server';
import IngenVarslerIkon from './assets/IngenVarslerIkon';
import VarselBjelleDotMedFyll from './assets/VarselBjelleDotMedFyll';
import VarselBjelleDotUtenFyll from './assets/VarselBjelleDotUtenFyll';
import { getLanguage } from '../../../utils/server/language';
import ClientError from '@shared/client-error/ClientError';
import PersonalContentLogger from '@shared/legacy/PersonalContentLogger';
import logger from '@utils/server/logger';
import style from './Varsler.module.css';

const audience = getAudience('tms-varsel-api');
const oboToken = await getOboToken(Astro.locals.token, audience);

let data = { oppgaver: 0, beskjeder: 0, innbokser: 0 };
let isError = false;

try {
  data = await fetchData(oboToken, VARSEL_API_URL);
} catch (error: any) {
  logger.error(`Fetching varsler failed. ${error.message}`);
  isError = true;
}

const oppgaver = data.oppgaver || 0;
const beskjeder = data.beskjeder + data.innbokser;
const varsler = beskjeder + oppgaver;

const language = getLanguage(Astro.url);
const oppgaveText = oppgaveSingular(oppgaver) ? text.oppgave[language] : text.oppgaver[language];
const beskjedText = beskjedSingular(beskjeder) ? text.beskjed[language] : text.beskjeder[language];
---

{isError && <ClientError client:only="react" />}
{
  !hasVarsler(varsler) ? (
    <a href={VARSLER_URL} class={style.varsler}>
      <IngenVarslerIkon />
      <div class={style.container}>
        <h3 class={style.heading}>{text.varsler[language]}</h3>
        <p class={style.tekst}>{text.ingenVarsler[language]}</p>
      </div>
    </a>
  ) : (
    <a href={VARSLER_URL} class={style.varsler}>
      <div class={style.ikonRektangel}>
        <VarselBjelleDotMedFyll />
        <VarselBjelleDotUtenFyll />
      </div>
      <div class={style.container}>
        <h3 class={style.heading}>{text.varsler[language]}</h3>
        <p class={style.tekst}>{buildText(beskjeder, oppgaver, beskjedText, oppgaveText, text.og[language])}</p>
      </div>
    </a>
  )
}

<PersonalContentLogger event={"varsler"} value={varsler > 0 ? true : false} client:only="react" />
