---
import { Skeleton, Heading } from "@navikt/ds-react";
import { getLanguage } from "../../../utils/server/language";
import { text } from "../utbetalingText";
import { utbetalingsoversiktUrl } from "../utbetalingUrls";
import style from "./UtbetalingFallback.module.css";

const language = getLanguage(Astro.url);
---

<div class={style.detaljer}>
  <div class={`${style.detaljerContainer}`}>
    <div class={style.heading}>
      <Heading level="2" size="xsmall">
        {text.tittelUtbetalinger[language]}
      </Heading>
    </div>
    <Skeleton width={116} height={28} />
    <Skeleton width={225} height={24} />
  </div>
  <div class={style.wrapper}>
    <a href={utbetalingsoversiktUrl} class={style.container}>
      <div class={style.ytelse}>
        <Skeleton width={225} height={24} />
        <Skeleton width={125} height={24} />
      </div>
      <div class={style.chevron} aria-hidden={true}></div>
    </a>
  </div>
</div>
