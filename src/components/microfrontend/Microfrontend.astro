---
import { getOboToken } from "../../utils/server/token";
import { getAudience } from "../../utils/server/token";

const audience = getAudience("tms-microfrontend-test");
const oboToken = getOboToken(Astro.locals.token, audience);

const url = "http://tms-microfrontend-test/tms-microfrontend-test";
const html = await fetch(url, {
  method: "GET",
  headers: {
    "Content-Type": "application/json",
    Accept: "application/json",
    Authorization: `Bearer ${oboToken}`,
  },
}).catch((e) => console.error("Failed to fetch ssr-microfrontend"));
---

<Fragment set:html={html} />